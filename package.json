{
  "name": "@whykusanagi/corrupted-theme",
  "version": "0.3.0",
  "type": "module",
  "description": "A dark, glassmorphic design system with pink/purple accents. Perfect for creating modern, visually striking web applications.",
  "main": "src/css/theme.css",
  "style": "src/css/theme.css",
  "exports": {
    ".": {
      "import": "./src/css/theme.css",
      "require": "./src/css/theme.css"
    },
    "./variables": "./src/css/variables.css",
    "./typography": "./src/css/typography.css",
    "./glassmorphism": "./src/css/glassmorphism.css",
    "./animations": "./src/css/animations.css",
    "./components": "./src/css/components.css",
    "./utilities": "./src/css/utilities.css",
    "./nikke-utilities": "./src/css/nikke-utilities.css",
    "./extensions": "./src/css/extensions.css",
    "./gallery": "./src/lib/gallery.js",
    "./lightbox": "./src/lib/lightbox.js",
    "./countdown": "./src/lib/countdown-widget.js",
    "./typing-animation": "./src/core/typing-animation.js",
    "./corrupted-text": "./src/lib/corrupted-text.js",
    "./corruption-loading": "./src/lib/corruption-loading.js",
    "./character-corruption": "./src/lib/character-corruption.js",
    "./components-js": "./src/lib/components.js",
    "./carousel": "./src/lib/carousel.js",
    "./corrupted-vortex": "./src/lib/corrupted-vortex.js",
    "./corrupted-particles": "./src/lib/corrupted-particles.js",
    "./corruption-charsets": "./src/core/corruption-charsets.js",
    "./decrypt-reveal": "./src/core/decrypt-reveal.js",
    "./crt-effects": "./src/lib/crt-effects.js",
    "./animation-blocks": "./src/lib/animation-blocks.js",
    "./corrupted-particles-background": "./src/lib/corrupted-particles-background.js",
    "./random-utils": "./src/core/random-utils.js",
    "./time-utils": "./src/core/time-utils.js",
    "./clipboard-helpers": "./src/core/clipboard-helpers.js",
    "./url-state": "./src/core/url-state.js",
    "./websocket-manager": "./src/core/websocket-manager.js",
    "./toast": "./src/lib/toast.js",
    "./toast-css": "./src/css/toast.css",
    "./clock-widget": "./src/lib/clock-widget.js",
    "./event-bar": "./src/lib/event-bar.js",
    "./logo-banner": "./src/lib/logo-banner.js",
    "./png-export": "./src/lib/png-export.js",
    "./nsfw-reveal": "./src/lib/nsfw-reveal.js",
    "./phrase-cycle": "./src/lib/phrase-cycle.js",
    "./chromatic-pulse": "./src/lib/chromatic-pulse.js",
    "./binary-particles": "./src/lib/binary-particles.js",
    "./glitch-title-card": "./src/lib/glitch-title-card.js",
    "./terminal-takeover": "./src/lib/terminal-takeover.js",
    "./stream-ticker": "./src/lib/stream-ticker.js",
    "./stream-overlays-css": "./src/css/stream-overlays.css",
    "./corrupted-mandala": "./src/lib/corrupted-mandala.js",
    "./corrupted-mandala-css": "./src/css/corrupted-mandala.css",
    "./terminal-vocab": "./src/core/terminal-vocab.js",
    "./abyssal-cables": "./src/lib/abyssal-cables.js",
    "./geometric-morpher": "./src/lib/geometric-morpher.js",
    "./neural-deserializer": "./src/lib/neural-deserializer.js",
    "./spectrum-terminal": "./src/lib/spectrum-terminal.js",
    "./transitions": "./src/lib/transitions/index.js",
    "./scroll-decode": "./src/lib/scroll-decode.js",
    "./corrupted-timeline": "./src/lib/corrupted-timeline.js",
    "./glitch-stagger-grid": "./src/lib/glitch-stagger-grid.js",
    "./corruption-easings": "./src/core/corruption-easings.js",
    "./seamless-background": "./src/css/seamless-background.css",
    "./data/phrases.json": "./src/data/phrases.json",
    "./data/charsets.json": "./src/data/charsets.json",
    "./data/colors.json": "./src/data/colors.json"
  },
  "files": [
    "src",
    "docs/brand",
    "docs/components",
    "docs/standards",
    "docs/platforms/NPM_PACKAGE.md",
    "docs/platforms/WEB_IMPLEMENTATION.md",
    "docs/platforms/COMPONENT_MAPPING.md",
    "docs/CDN_CONSUMPTION.md",
    "docs/COMPONENTS_REFERENCE.md",
    "docs/CORRUPTION_PHRASES.md",
    "docs/CHARACTER_LEVEL_CORRUPTION.md",
    "docs/CROSS_LANGUAGE_CONTRACT.md",
    "docs/MIGRATION_CONTAINER_0.2.0.md",
    "docs/RENDER_TO_VIDEO.md",
    "docs/STYLE_GUIDE.md",
    "examples",
    "Dockerfile",
    "docker-entrypoint.sh",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/whykusanagi/corrupted-theme.git"
  },
  "keywords": [
    "css",
    "theme",
    "design-system",
    "glassmorphism",
    "dark-mode",
    "ui-framework",
    "styling",
    "css-variables",
    "gallery",
    "lightbox",
    "countdown",
    "social-links",
    "link-in-bio"
  ],
  "author": "whykusanagi <contact@whykusanagi.xyz>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "cssnano": "^8.0.2",
    "eslint": "^10.6.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "postcss": "^8.5.16",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "rollup": "^4.62.2"
  },
  "scripts": {
    "data:generate": "node scripts/inline-data.js",
    "manifest:generate": "node scripts/generate-manifest.js",
    "prebuild": "npm run data:generate",
    "build": "postcss src/css/theme.css -o dist/theme.min.css",
    "build:umd": "rollup -c rollup.config.js",
    "watch": "postcss --watch src/css/theme.css -o dist/theme.min.css",
    "dev:proxy": "node scripts/celeste-proxy-server.js",
    "dev:static": "node scripts/static-server.js",
    "start": "npm run dev:static",
    "validate-data": "node scripts/validate-data.js",
    "pretest": "npm run data:generate",
    "test": "node --test --test-reporter=spec 'tests/**/*.test.js'",
    "publish-cdn": "bash scripts/publish-to-cdn.sh",
    "generate-sri": "bash scripts/generate-sri.sh",
    "prepublishOnly": "npm run data:generate && npm run build && npm run manifest:generate && npm test",
    "nav:sync": "node scripts/sync-nav.js",
    "lint:security": "eslint ."
  },
  "homepage": "https://github.com/whykusanagi/corrupted-theme#readme",
  "bugs": {
    "url": "https://github.com/whykusanagi/corrupted-theme/issues"
  },
  "peerDependencies": {
    "html2canvas": ">=1.4.0"
  },
  "peerDependenciesMeta": {
    "html2canvas": {
      "optional": true
    }
  }
}
