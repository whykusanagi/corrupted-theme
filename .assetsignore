# Cloudflare Workers Static Assets ignore file
# Used by `wrangler deploy` when the Worker's assets.directory is the repo root.
# Wrangler does NOT respect .gitignore, so dev artifacts + internal docs must be
# listed here explicitly. Syntax is gitignore-style (supports globs).
# Docs: https://developers.cloudflare.com/workers/static-assets/binding/#ignoring-files

# -----------------------------------------------------------------------------
# Build-time artifacts (installed into the CF build environment, not shipped)
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Git + CI metadata (shouldn't be publicly served)
# -----------------------------------------------------------------------------
.git/
.github/
.gitignore

# -----------------------------------------------------------------------------
# Wrangler config + Worker script (bundled separately, not served as assets)
# -----------------------------------------------------------------------------
.wrangler/
wrangler.jsonc
wrangler.toml
worker/

# -----------------------------------------------------------------------------
# This ignore file itself
# -----------------------------------------------------------------------------
.assetsignore

# -----------------------------------------------------------------------------
# AI development policy (not intended for the public site)
# -----------------------------------------------------------------------------
CLAUDE.md

# -----------------------------------------------------------------------------
# Internal specs (mirrors .npmignore — kept in repo for history,
# never meant to ship publicly)
# -----------------------------------------------------------------------------
CORRUPTED_THEME_SPEC.md
CORRUPTION_BUFFER_IMPLEMENTATIONS.md

# -----------------------------------------------------------------------------
# Internal planning docs (kept in repo for history, not for the public site)
# -----------------------------------------------------------------------------
docs/planning/

# -----------------------------------------------------------------------------
# Internal maintainer docs + governance process (owner rule 2026-07-05:
# internal notes are never publicly served — consumer guidance lives in the
# README and dist/llms.txt)
# -----------------------------------------------------------------------------
docs/IMPLEMENTATION_NOTES.md
docs/governance/

# -----------------------------------------------------------------------------
# Internal tooling + CI tests + CDN worker source (not site content)
# -----------------------------------------------------------------------------
scripts/
tests/
cdn-worker/

# -----------------------------------------------------------------------------
# Local AI session data (untracked, listed defensively)
# -----------------------------------------------------------------------------
.claude/

# -----------------------------------------------------------------------------
# Lockfiles + package manifest (public can inspect via npmjs — no need to ship)
# -----------------------------------------------------------------------------
package-lock.json
bun.lockb
bun.lock

# -----------------------------------------------------------------------------
# OS + editor junk
# -----------------------------------------------------------------------------
.DS_Store
._*
.AppleDouble
.Spotlight-V100
.Trashes
.vscode/
.idea/
*.swp

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*

# -----------------------------------------------------------------------------
# Docker artifacts (not meant for the web deployment)
# -----------------------------------------------------------------------------
Dockerfile
docker-entrypoint.sh
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Local-only scratch (never committed but listed defensively)
# -----------------------------------------------------------------------------
CLAUDE.local.md
notes/CLAUDE-scratch.md
.env
.env.*
.secrets/
*.key
